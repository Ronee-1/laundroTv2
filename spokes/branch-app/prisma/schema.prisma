// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id_user    String   @id @default(cuid())
  nama       String
  email      String   @unique
  password   String
  role       String   // 'Owner' | 'Admin' | 'Kurir'
  id_cabang  String?
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  branch     Branch?  @relation(fields: [id_cabang], references: [id_cabang])

  @@index([email])
  @@index([id_cabang])
  @@index([role])
}

model Branch {
  id_cabang      String   @id
  nama_cabang    String
  alamat         String
  latitude       Float
  longitude      Float
  kuota_harian   Int      @default(30)
  kuota_terpakai Int      @default(0)
  is_active      Boolean  @default(true)
  omzet          Float    @default(0)
  wilayah        String
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  users          User[]
  cashbook_entries      CashBookEntry[]
  couriers              Courier[]
  orders                Order[]
  expenses              Expense[]
  monthly_budgets        MonthlyBudget[]
  inventory_items       InventoryItem[]
  reconciliations       ReconciliationLog[]
  restock_requests      RestockRequest[]
  logistics_logs        LogisticsLog[]
  customers             Customer[]
}

model CashBookEntry {
  id_jurnal      String   @id @default(cuid())
  id_cabang      String
  id_transaksi   String
  nominal        Float
  tipe           String
  deskripsi      String
  tanggal_jurnal DateTime @default(now())
  created_at     DateTime @default(now())
  branch         Branch   @relation(fields: [id_cabang], references: [id_cabang])

  @@index([id_cabang])
  @@index([tipe])
}

model Courier {
  id_kurir       String   @id
  id_cabang      String
  nama_kurir     String
  nomor_telepon  String
  is_available   Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
  branch         Branch   @relation(fields: [id_cabang], references: [id_cabang])
  orders         Order[]

  @@index([id_cabang])
  @@index([is_available])
}

model Order {
  id_order               String    @id
  id_cabang              String
  id_pelanggan           String    @default("")
  id_kurir               String?
  alamat_penjemputan     String
  alamat_pengantaran     String
  latitude_penjemputan   Float
  longitude_penjemputan  Float
  latitude_pengantaran   Float
  longitude_pengantaran  Float
  status                 String    @default("Pending")
  catatan                String?
  berat_kg               Float?
  total_harga            Float?
  tanggal_order          DateTime  @default(now())
  tanggal_selesai        DateTime?
  customer_name          String?
  customer_whatsapp      String?
  service_type           String?
  service_name           String?
  qty                    Float?
  satuan                 String?
  wilayah                String?
  google_maps_url        String?
  source                 String?
  assigned_by            String?
  assigned_at            DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  branch                 Branch    @relation(fields: [id_cabang], references: [id_cabang])
  courier                Courier?  @relation(fields: [id_kurir], references: [id_kurir])

  @@index([id_cabang])
  @@index([id_kurir])
  @@index([status])
  @@index([source])
  @@index([tanggal_order])
}

model Expense {
  id_expense        String    @id @default(cuid())
  id_cabang         String
  tanggal           DateTime
  nominal           Float
  deskripsi         String
  kategori          String
  bukti_nota_url    String    @default("")
  status            String    @default("Pending")
  tanggal_pengajuan DateTime  @default(now())
  tanggal_approval  DateTime?
  catatan_approval String?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  branch            Branch    @relation(fields: [id_cabang], references: [id_cabang])

  @@index([id_cabang])
  @@index([status])
  @@index([kategori])
}

model MonthlyBudget {
  id             String @id @default(cuid())
  id_cabang      String
  bulan          String
  tahun          Int
  pagu_anggaran  Float
  terpakai       Float  @default(0)
  branch         Branch @relation(fields: [id_cabang], references: [id_cabang])

  @@unique([id_cabang, bulan, tahun])
  @@index([id_cabang])
}

model InventoryItem {
  id               String @id @default(cuid())
  id_cabang        String
  item             String
  satuan           String
  stok_saat_ini    Int
  safety_threshold Int
  max_capacity     Int
  branch           Branch @relation(fields: [id_cabang], references: [id_cabang])

  @@unique([id_cabang, item])
  @@index([id_cabang])
}

model ReconciliationLog {
  id_rekonsiliasi String   @id @default(cuid())
  id_cabang       String
  tanggal         DateTime @default(now())
  kas_digital     Float
  kas_fisik       Float
  selisih         Float
  status          String
  approval_status String   @default("Pending")
  catatan         String?
  catatan_owner   String?
  created_at      DateTime @default(now())
  branch          Branch   @relation(fields: [id_cabang], references: [id_cabang])

  @@index([id_cabang])
  @@index([status])
  @@index([approval_status])
}

model RestockRequest {
  id_request      String    @id @default(cuid())
  id_cabang       String
  nama_cabang     String
  created_by      String
  requested_items Json
  status          String    @default("Pending")
  catatan         String?
  reviewed_by     String?
  reviewed_at     DateTime?
  created_at      DateTime  @default(now())
  branch          Branch    @relation(fields: [id_cabang], references: [id_cabang])

  @@index([id_cabang])
  @@index([status])
}

model LogisticsLog {
  id             String   @id @default(cuid())
  id_cabang      String
  sent_items     Json
  received_items Json?
  discrepancy    Json?
  status         String   @default("In-Transit")
  timestamp      DateTime @default(now())
  branch         Branch   @relation(fields: [id_cabang], references: [id_cabang])

  @@index([id_cabang])
  @@index([status])
}

model ServiceTariff {
  id_layanan       String  @id
  nama_layanan     String
  kategori         String
  satuan           String
  harga_per_satuan Float
  estimasi_hari    Int
  is_active        Boolean @default(true)
}

model ExpenseCategory {
  id   String @id @default(cuid())
  name String @unique
}

model CourierTaskSequence {
  id        String @id @default(cuid())
  id_kurir  String
  id_order  String
  urutan    Int

  @@unique([id_kurir, id_order])
  @@index([id_kurir])
}

model InventoryAnomaly {
  id            String   @id @default(cuid())
  id_cabang     String
  nama_cabang  String
  item          String
  stok_lama     Int
  stok_baru     Int
  alasan        String
  timestamp     DateTime @default(now())

  @@index([id_cabang])
}

model Customer {
  id_pelanggan    String   @id @default(cuid())
  id_cabang       String
  nama            String
  whatsapp        String
  alamat_maps     String
  google_maps_url String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  branch          Branch   @relation(fields: [id_cabang], references: [id_cabang])

  @@index([id_cabang])
}
