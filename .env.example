# ============================================
# LaundroT Environment Variables Template
# ============================================
#
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES
# NEVER COMMIT .env.local TO VERSION CONTROL
#
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
# For Vercel Postgres, use the connection string from your Vercel dashboard
# Format: postgresql://user:password@host:5432/database?sslmode=require

DATABASE_URL=postgresql://username:password@host:5432/laundrot?sslmode=require

# Alternative: Supabase
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Alternative: Neon
# DATABASE_URL=postgresql://username:password@ep-xxx-xxx-xxx.region.aws.neon.tech/laundrot?sslmode=require

# ============================================
# AUTHENTICATION
# ============================================
# IMPORTANT: Generate a secure secret for production!
# Generate with: openssl rand -base64 32

JWT_SECRET=your-super-secret-jwt-key-generate-with-openssl-rand-base64-32
JWT_EXPIRES_IN=7d

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
# For production, add your Vercel domain:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://*.vercel.app

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ============================================
# APPLICATION SETTINGS
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# OPTIONAL: Third-party Services
# ============================================

# Google Maps API (for location services)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# WhatsApp Business API (for notifications)
# WHATSAPP_API_KEY=your-whatsapp-api-key
# WHATSAPP_PHONE_NUMBER=6281234567890

# ============================================
# DEVELOPMENT ONLY (not needed in production)
# ============================================
# DATABASE_URL for local development
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/laundrot
