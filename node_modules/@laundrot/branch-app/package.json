{
  "name": "@laundrot/branch-app",
  "version": "1.0.0",
  "private": true,
  "description": "Branch-specific courier frontend (React PWA)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npx prisma generate && vite build",
    "build:full": "npx prisma generate && tsc -b && vite build",
    "postinstall": "prisma generate",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.5.2",
    "postcss": "^8.5.16",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  },
  "prisma": {
    "schema": "./prisma/schema.prisma"
  }
}
